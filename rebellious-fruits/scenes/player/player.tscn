[sub_resource type="GDScript" id="GDScript_p47bc"]
script/source = "extends CharacterBody2D
# ==========================================
# CÀI ĐẶT NHÂN VẬT
# ==========================================
@export var speed: float = 200.0          # Tốc độ chạy (pixel/s)
@export var jump_force: float = -450.0    # Lực nhảy (âm = lên trên)
@export var gravity: float = 1200.0       # Trọng lực
# ==========================================
# THAM CHIẾU ĐẾN CÁC NODE CON
# ==========================================
@onready var sprite: AnimatedSprite2D = $AnimatedSprite2D
# ==========================================
# BIẾN NỘI BỘ
# ==========================================
var is_dead: bool = false
# ==========================================
# HÀM CHÍNH
# ==========================================
func _physics_process(delta: float) -> void:
	if is_dead:
		return
	
	_apply_gravity(delta)
	_handle_movement()
	_handle_jump()
	_update_animation()
	
	move_and_slide()
# ==========================================
# XỬ LÝ TRỌNG LỰC
# ==========================================
func _apply_gravity(delta: float) -> void:
	if not is_on_floor():
		velocity.y += gravity * delta
# ==========================================
# XỬ LÝ DI CHUYỂN NGANG
# ==========================================
func _handle_movement() -> void:
	var direction: float = Input.get_axis(\"ui_left\", \"ui_right\")
	
	if direction != 0:
		velocity.x = direction * speed
		# Lật sprite theo hướng di chuyển
		sprite.flip_h = direction < 0
	else:
		# Giảm tốc mượt khi thả phím
		velocity.x = move_toward(velocity.x, 0, speed)
# ==========================================
# XỬ LÝ NHẢY
# ==========================================
func _handle_jump() -> void:
	if Input.is_action_just_pressed(\"ui_accept\") and is_on_floor():
		velocity.y = jump_force
# ==========================================
# CẬP NHẬT ANIMATION
# ==========================================
func _update_animation() -> void:
	if not is_on_floor():
		# Đang trên không — có thể thêm animation jump sau
		pass
	elif abs(velocity.x) > 10:
		sprite.play(\"Run\")
	else:
		sprite.play(\"Idle\")
# ==========================================
# HÀM CHẾT
# ==========================================
func die() -> void:
	if is_dead:
		return
	is_dead = true
	sprite.play(\"Die\")
	# Tắt va chạm để không bị kẹt
	$CollisionShape2D.set_deferred(\"disabled\", true)
"

